# =====================================================
# ВкусМаркет — переменные окружения
# =====================================================
# Скопируйте этот файл в `.env.local` (он не попадает в git)
# и заполните значения после регистрации в нужных сервисах.
#
# В Vercel переменные настраиваются в разделе:
#   Settings → Environment Variables.
# =====================================================

# --- Админ-панель ---
# Логин и пароль для входа в /admin/login.
# По умолчанию: admin / vkusno2025 (рекомендуем поменять!).
ADMIN_LOGIN=admin
ADMIN_PASSWORD=vkusno2025

# --- Telegram-уведомления о новых заказах ---
# 1. Создайте бота через @BotFather в Telegram → команда /newbot.
# 2. Скопируйте токен из ответа BotFather.
# 3. Напишите своему боту любое сообщение (он "увидит" вас).
# 4. Чтобы узнать ваш chat_id, откройте в браузере:
#    https://api.telegram.org/bot<ВАШ_ТОКЕН>/getUpdates
#    и найдите поле "chat":{"id": ... }
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# --- SMS-провайдер (отправка кодов для входа) ---
# Поддерживается два провайдера: SMSC.ru (по умолчанию, дешевле) и SMS.ru
# (есть free dev-тариф). Если оба пустые — приложение работает в демо-режиме:
# код всегда `123456`, что показано пользователю на форме входа.
#
# Явный выбор провайдера (опционально):
#   SMS_PROVIDER=smsc   — использовать SMSC.ru
#   SMS_PROVIDER=smsru  — использовать SMS.ru
#   SMS_PROVIDER=demo   — принудительный демо-режим
#   (пусто)             — автовыбор первого сконфигурированного
SMS_PROVIDER=

# SMSC.ru (https://smsc.ru/). Регистрация → личный кабинет → пополните баланс.
# Логин + пароль кабинета. Если хотите хранить md5(пароль), укажите
# SMSC_PASSWORD_IS_MD5=1. SMSC_SENDER — буквенный сендер (нужно согласовать).
SMSC_LOGIN=
SMSC_PASSWORD=
SMSC_PASSWORD_IS_MD5=
SMSC_SENDER=

# SMS.ru (https://sms.ru/). Зарегистрируйтесь → получите api_id.
SMSRU_API_ID=
SMSRU_SENDER=

# --- Supabase (база данных для заказов и курьеров) ---
# Создайте проект на https://supabase.com/
# Project Settings → API:
#   Project URL          → NEXT_PUBLIC_SUPABASE_URL
#   anon public          → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   service_role secret  → SUPABASE_SERVICE_ROLE_KEY (никому не показывайте!)
# Если переменные пустые, приложение работает в режиме in-memory:
# заказы и курьеры хранятся в памяти процесса Vercel и сбрасываются
# при холодных стартах. Достаточно для демо, но не для продакшена.
# После заполнения — выполните SQL из supabase/migrations/0001_initial_schema.sql
# в Supabase SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Яндекс.Карты (геолокация и карта в заказах) ---
# Получите API-ключ на https://developer.tech.yandex.ru/
# Тариф JavaScript API + HTTP Geocoder бесплатный для старта.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=

# --- ЮKassa (оплата картой + 54-ФЗ чеки) ---
# https://yookassa.ru/ для ИП. Test-режим:
#   YOOKASSA_SHOP_ID = test-shop-id
#   YOOKASSA_SECRET_KEY = test_xxx...
# Если пустые — приложение работает в demo-режиме: после нажатия «Оплатить»
# клиента редиректит на /api/payments/yookassa/demo-callback, который
# моментально переводит платёж в succeeded и возвращает на /orders.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Куда ЮKassa возвращает клиента после оплаты. По умолчанию используется
# NEXT_PUBLIC_SITE_URL. Полезно переопределить для preview-деплоев.
YOOKASSA_RETURN_URL=

# Налоговая система для чека 54-ФЗ. Значения по справочнику ЮKassa:
#   1 = ОСН, 2 = УСН доход (по умолчанию для ИП на УСН),
#   3 = УСН доход минус расход, 4 = ЕНВД (устарело), 5 = ЕСХН, 6 = ПСН.
YOOKASSA_TAX_SYSTEM=2

# Ставка НДС по умолчанию (для всех позиций чека):
#   1 = без НДС (УСН без НДС — для ИП на УСН по умолчанию)
#   2 = НДС 0%, 3 = НДС 10%, 4 = НДС 20%
#   5 = НДС 10/110, 6 = НДС 20/120
PAYMENT_DEFAULT_VAT_CODE=1

# Публичный URL сайта (используется как fallback для return_url).
NEXT_PUBLIC_SITE_URL=https://vkusnomarket05.vercel.app
